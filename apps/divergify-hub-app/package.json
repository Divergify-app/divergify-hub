{
  "name": "divergify-hub-app",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.app.json --noEmit && vite build",
    "test": "vitest run",
    "preview": "vite preview",
    "check": "npm run build",
    "cap:sync": "npm run build && npx cap sync",
    "android:release": "./scripts/build_android_release.sh",
    "cap:android": "npm run build && npx cap add android && npx cap sync android",
    "cap:ios": "npm run build && npx cap add ios && npx cap sync ios"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@netlify/functions": "^5.1.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.26.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@vitejs/plugin-react-swc": "^3.5.0",
    "typescript": "^5.6.3",
    "vite": "^6.4.3",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.9"
  }
}
